            // "overviewRulerColor": ""
        }
    ],
    "todohighlight.keywordsPattern": "",
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "editor.semanticHighlighting.enabled": true,
    "editor.semanticTokenColorCustomizations": {
        "[Gruvbox Dark Hard]": {
            "enabled": true,
            "rules": {
                "*.builtin": "#7672ff",
                "variable.builtin": "#fd96ff",
                "builtinConstant": "#fb4934",
                "*.readonly": {
                    "bold": true,
                    "italic": true,
                },
                "variable.readonly": {
                    "foreground": "#fc53ff",
                },
                "variable": "#ebdbb2",
                "property": "#2fc1ff",
                "class": "#ee8f09",
                "*.typeHint": "#eeee09",
                "function": "#5395ff",
                "function.readonly": {
                    "foreground": "#8a63ff",
                },
                "selfParameter": {
                    "foreground": "#a953ff",
                    "fontStyle": "italic bold"
                },
                "clsParameter": {
                    "foreground": "#ee8f09",
                    "fontStyle": "italic bold"
                },
                "method": "#7c6cf6",
                "parameter": "#53ff98",
                "parameter.declaration": {
                    "underline": true
                },
                "number": "#ffb4b4",
                "*.decorator": "#ff8000"
            }
        },
        "[Default Light+][Light+]": {
            "enabled": true,
            "rules": {
                "*.builtin": {
                    "foreground": "#5c57ff",
                    "bold": true,
                    "italic": true,
                },
                "variable.builtin": "#cb00ce",
                "builtinConstant.readonly": {
                    "foreground": "#ff0000",
                    "bold": false,
                    "italic": false,
                },
                "*.readonly": {
                    "bold": true,
                    "italic": true,
                },
                "variable.readonly": {
                    "foreground": "#fb00ff",
                },
                "property.readonly": {
                    "foreground": "#ff53a9",
                },
                "variable": "#000000",
                "property": "#6d2c00",
                "class": "#d58a00",
                "*.typeHint": "#c0c000",
                "typeParameter": "#8dc000",
                "function": "#0062ff",
                // "magicFunction": "#5395ff",
                // "magicFunction.declaration": "#5395ff",
                // "function.readonly": {
                //     "foreground": "#8a63ff",
                // },
                "selfParameter": {
                    "foreground": "#b300ff",
                    "fontStyle": "italic bold"
                },
                "clsParameter": {
                    "foreground": "#d58a00",
                    "fontStyle": "italic bold"
                },
                "method": "#b300ff",
                "parameter": "#00ae6b",
                "parameter.declaration": {
                    "underline": true
                },
                "number": "#00D4D7",
                "*.decorator": "#ff8000",
                "*.deprecated": {
                    "strikethrough": true
                },
            }
        },
    },
    "window.autoDetectColorScheme": true,
    "workbench.preferredDarkColorTheme": "Gruvbox Dark Hard",
    "workbench.preferredLightColorTheme": "Light+",
