    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.inlayHints.fontFamily": "Nachlieli CLM, Lucida Calligraphy",
    "editor.trimAutoWhitespace": false,
    "npm.keybindingsChangedWarningShown": true,
    "editor.guides.bracketPairs": "active",
    "editor.tokenColorCustomizations": {
        "[Default Dark+]": {
            "keywords": "#fb4934"
        },
        "[Default Light+][Light+]": {
            "textMateRules": [
                {
                    "scope": "keyword",
                    "settings": {
                        "foreground": "#ff0000",
                    }
                },
                {
                    "scope": "keyword.operator",
                    "settings": {
                        "fontStyle": "bold",
                    }
                },
                {
                    "scope": "variable.other.constant",
                    "settings": {
                        "foreground": "#a65050",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": [
                        "punctuation.bracket",
                        "punctuation.definition.parameters.end.bracket",
                        "punctuation.definition.parameters.begin.bracket",
                    ],
                    "settings": {
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "punctuation.definition.string.begin",
                    "settings": {
                        "foreground": "#059100",
                    }
                },
                {
                    "scope": "punctuation.definition.string.end",
                    "settings": {
                        "foreground": "#059100",
                        "fontStyle": "underline"
                    }
                },
                {
                    "scope": "string.regexp",
                    "settings": {
                        "foreground": "#059100",
                        "fontStyle": "underline"
                    }
                },
                {
                    "scope": "constant.character.escape.regexp",
                    "settings": {
                        "foreground": "#059100",
                        "fontStyle": "underline"
                    }
                },
                {
                    "scope": "storage.type.number",
                    "settings": {
                        "foreground": "#00D4D7",
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "entity.name.function.decorator",
                    "settings": {
                        "foreground": "#cc5e00",
                    }
                },
                
                
                // ============== PYTHON =============
                {
                    "scope": "storage.type.string.python",
                    "settings": {
                        "foreground": "#059100",
                        "fontStyle": "bold italic"
                    }
                },
                {
                    "scope": "punctuation.definition.arguments.begin.python",
                    "settings": {
                        "foreground": "#000",
                    }
                },
                
                // ============== Rust =============
                // {
                //     "scope": "entity.name.type.numeric.rust",
                //     "settings": {
                //         "fontStyle": "italic",
                //     }
                // },
            ],
            "keywords": "#FF0000",
            "comments": {
                "foreground": "#079000",
                "fontStyle": "bold",
            },
            "functions": "#0000ff",
            "strings": "#079000",
            // "variables": "#00ffdd",
            "types": "#a29800",
            "numbers": {
                "fontStyle": "bold",
                "foreground": "#00d4d7"
            },
        },
        "[Gruvbox Dark Hard]": {
            "textMateRules": [
                {
                    "scope": "constant.other",
                    "settings": {
                        "foreground": "#ff7878"
                    }
                },
                {
                    "scope": "punctuation.definition.string.begin",
                    "settings": {
                        "foreground": "#07d800",
                    }
                },
                {
                    "scope": "punctuation.definition.string.end",
                    "settings": {
                        "foreground": "#07d800",
                        "fontStyle": "underline"
                    }
                },
                {
                    "scope": "string.regexp",
                    "settings": {
                        "foreground": "#77ff00",
                        "fontStyle": "underline"
                    }
                },
                {
                    "scope": "constant.character.escape.regexp",
                    "settings": {
                        "foreground": "#77ff00",
                        "fontStyle": "underline"
                    }
                },
                {
                    "scope": "storage.type.string.python",
                    "settings": {
                        "foreground": "#08ed00",
                        "fontStyle": "bold italic"
                    }
                },
                {
                    "scope": "keyword.operator.logical",
                    "settings": {
                        "foreground": "#FB4934",
                    }
                },
                // {
                //     "scope": "support.function.builtin.python",
                //     "settings": {
                //         "foreground": "#3d47ff"
                //     }
                // },
                // {
                //     "scope": "source.python",
                //     "settings": {
                //         "foreground": "#ff5353",
                //     }
                // },
                {
                    "scope": "entity.name.function.python",
                    "settings": {
                        "foreground": "#5395ff"
                    }
                },
                {
                    "scope": "variable.parameter",
                    "settings": {
                        "foreground": "#53ff98"
                    }
                },
                {
                    "scope": "meta.function.parameter",
                    "settings": {
                        "foreground": "#53ff98"
                    }
                },
                {
                    "scope": "variable.language.special.self.python",
                    "settings": {
                        "foreground": "#a953ff",
                        "fontStyle": "italic bold"
                    }
                },
                // {
                //     "scope": "variable.parameter.function.language.special.self.python",
                //     "settings": {
                //         "foreground": "#a953ff",
                //         "fontStyle": "italic bold underline"
                //     }
                // },
                // {
                //     "scope": "variable.parameter",
                //     "settings": {
                //         "foreground": "#53ff98",
                //         "fontStyle": "underline"
                //     }
                // },
                // {
                //     "scope": "source.python",
                //     "settings": {
                //         "foreground": "#ffb4b4"
                //     }
                // },
                {
                    "scope": "keyword.operator",
                    "settings": {
                        "foreground": "#ffffff",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "punctuation",
                    "settings": {
                        "foreground": "#ebdbb2"
                    }
                },
                {
                    "scope": "meta.parameter.type.variable",
                    "settings": {
                        "foreground": "#ebdbb2",
                        "fontStyle": "underline strikethrough"
                    }
                },
                {
                    // Used to colorize type inference, as this is the only thing left uncolorized
                    "scope": "meta.function.parameters.python",
                    "settings": {
                        "foreground": "#eeee09"
                    }
                },
                {
                    // Used to colorize type inference, as this is the only thing left uncolorized
                    "scope": "storage.type.number.python",
                    "settings": {
                        "foreground": "#ffef78"
                    }
                },
                // {
                //     "scope": "variable.parameter.function.python",
                //     "settings": {
                //         "foreground": "#ff0000",
                //         "fontStyle": "underline"
                //     }
                // }
                // ----------------- HTML5 -----------------
                {
                    "scope": "meta.attribute.href.html",
                    "settings": {
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "punctuation.definition.tag",
                    "settings": {
                        "foreground": "#ffffff",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "punctuation.separator.key-value.html",
                    "settings": {
                        "foreground": "#ffffff",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "entity.other.attribute-name.html",
                    "settings": {
                        "foreground": "#53ff98"
                    }
                },
                {
                    "scope": "entity.name.tag.html",
                    "settings": {
                        "foreground": "#eeee09"
                    }
                },
                // ----------------- CSS -----------------
                {
                    "scope": "keyword.other.unit",
                    "settings": {
                        "foreground": "#00fbff"
                    }
                },
                {
                    "scope": "entity.name.tag.css",
                    "settings": {
                        "foreground": "#eeee09"
                    }
                },
                {
                    "scope": "punctuation",
                    "settings": {
                        "foreground": "#ffffff",
                        "fontStyle": "bold"
                    }
                },
                // ----------------- JavaScript -----------------
                {
                    "scope": [
                        "storage.type.function",
                        "keyword.operator.new",
                        "storage.modifier",
                        "keyword.operator.expression",
                        "constant.language.undefined",
                        "constant.language",
                    ],
                    "settings": {
                        "foreground": "#fb4934"
                    }
                },
                {
                    "scope": [
                        "storage.type.function.arrow",
                        "keyword.operator"
                    ],
                    "settings": {
                        "foreground": "#ffffff",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "variable.language.this",
                    "settings": {
                        "foreground": "#a953ff",
                        "fontStyle": "italic bold"
                    }
                },
                {
                    "scope": "punctuation.definition.string",
                    "settings": {
                        "foreground": "#07d800",
                        "fontStyle": "bold"
                    }
                },
                {
                    "scope": "punctuation.definition.string.template.end",
                    "settings": {
                        "fontStyle": "underline"
                    }
                },
                {
                    "scope": [
                        "variable.other.object.property",
                        "variable.other.property"
                    ],
                    "settings": {
                        "foreground": "#2fc1ff"
                    }
                },
                {
                    "scope": [
                        "variable.other.jsdoc",
                    ],
                    "settings": {
                        "foreground": "#53ff98"
                    }
                },
                {
                    "scope": [
                        "storage.type",
                    ],
                    "settings": {
                        "foreground": "#FB4934"
                    }
                },
                {
                    "scope": [
                        "meta.attribute.unrecognized.trkey.html",
                        "meta.attribute.unrecognized.trattributes.html",
                    ],
                    "settings": {
                        "fontStyle": "bold italic",
                    }
                },
            ],
            "comments": "#05a000",
            "functions": "#5395ff",
            "strings": "#06b900",
            // "variables": "#00ffdd",
            "types": "#eeee09",
            "numbers": "#00fbff",
        },
    },
    "todohighlight.include": [
        "**/*.js",
        "**/*.jsx",
        "**/*.ts",
        "**/*.tsx",
        "**/*.html",
        "**/*.py",
        "**/*.gd",
        "**/*.php",
        "**/*.css",
        "**/*.scss"
    ],
    "todohighlight.keywords": [
        {
            "text": "TODO",
            "color": "white",
            "backgroundColor": "blue"
        },
        {
