            // "editorInlayHint.parameterForeground": "#ffffffcc",
            // "editorInlayHint.typeBackground": "#4d4d4d99",
            "editorInlayHint.typeForeground": "#d8d400cc",
        },
        "[Default Light+][Light+]": {
            "foreground": "#000",
            // "selection.background": "#1e00ff8d",
            // "editor.selectionHighlightBorder": "#1aff00",
            // "editor.selectionHighlightBackground": "#00000000",
            // "editor.selectionBackground": "#1e00ff8d",
            // "editor.hoverHighlightBackground": "#ffffff13",
            // "focusBorder": "#3c3836",
            // "foreground": "#ebdbb2",
            // "statusBar.background": "#116b0c",
            // "statusBar.foreground": "#ffffff",
            // "statusBar.noFolderBackground": "#1553aa",
            // "statusBar.noFolderForeground": "#ffffff",
            // "statusBar.debuggingBackground": "#885a04",
            // "statusBar.debuggingForeground": "#ffffff",
            "editorBracketHighlight.foreground1": "#000",
            "editorBracketHighlight.foreground2": "#ff00fb",
            "editorBracketHighlight.foreground3": "#0dbd00",
            // "editorBracketHighlight.foreground4": "#00b7ff",
            "editorBracketHighlight.unexpectedBracket.foreground": "#ff2018",
            // "editor.foldBackground": "#00000055",
            // "scrollbarSlider.background": "#ffffff",
            // "scrollbarSlider.hoverBackground": "#d5d5d53a",
            "scrollbarSlider.activeBackground": "#ff00e629",
            "editorStickyScroll.background": "#f2f2f277",
            
            // Inlay hints
            "editorInlayHint.background": "#ffffff99",
            "editorInlayHint.foreground": "#00000053",
            // "editorInlayHint.background": "#00000099",
            // "editorInlayHint.foreground": "#ffffff",
            // "editorInlayHint.parameterBackground": "#00000099",
            // "editorInlayHint.parameterForeground": "#ffffff",
