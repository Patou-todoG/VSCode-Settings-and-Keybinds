            "editorBracketHighlight.foreground3": "#ffff00",
            "editorBracketHighlight.foreground4": "#ff00fb",
            "editorBracketHighlight.foreground5": "#15ff00",
            "editorBracketHighlight.foreground6": "#846eff",
